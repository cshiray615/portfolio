---
import { getCollection, render } from 'astro:content';
import HobbyDetail from '~/layouts/HobbyDetail.astro';
import BeforeAfter from '~/components/case-study/BeforeAfter.astro';
import Figure from '~/components/case-study/Figure.astro';

export async function getStaticPaths() {
  const projects = await getCollection('hobby-projects');
  return projects
    .filter((p) => p.data.favorite)
    .map((p) => ({
      params: { category: p.data.category, slug: p.id },
      props: { project: p },
    }));
}

const { project } = Astro.props;
const { Content } = await render(project);
---

<HobbyDetail project={project}>
  <Content components={{ BeforeAfter, Figure }} />
</HobbyDetail>
