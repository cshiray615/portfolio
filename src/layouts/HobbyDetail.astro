---
import Base from '~/layouts/Base.astro';
import HobbyHero from '~/components/hobby/HobbyHero.astro';
import HobbyNavigation from '~/components/hobby/HobbyNavigation.astro';
import Lightbox from '~/components/case-study/Lightbox.astro';
import type { CollectionEntry } from 'astro:content';
import { getEntry } from 'astro:content';

export interface Props {
  project: CollectionEntry<'hobby-projects'>;
}

const { project } = Astro.props;
const category = await getEntry('hobby-categories', project.data.category);
---

<Base
  title={`${project.data.title} — ${category?.data.name ?? 'Hobby'} — Casey Shiray`}
  description={project.data.caption}
>
  <HobbyHero project={project} />
  <section class="hd-body">
    <div class="container">
      <slot />
    </div>
  </section>
  <HobbyNavigation project={project} />
  <Lightbox />
</Base>

<style>
  .hd-body { padding: 64px 0 32px; }
  .hd-body :global(h2) {
    font-family: var(--font-mono);
    font-size: 18px;
    font-weight: 700;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--vermillion);
    margin: 40px 0 16px;
  }
  .hd-body :global(h3) {
    margin-top: 32px;
    margin-bottom: 12px;
    font-size: clamp(20px, 2vw, 26px);
  }
  .hd-body :global(p) {
    font-size: 17px;
    line-height: 1.7;
    margin-bottom: 16px;
    max-width: 720px;
    color: var(--text);
  }
  .hd-body :global(em) { font-family: var(--font-serif); font-style: italic; }
  .hd-body :global(strong) { font-weight: 700; }
  .hd-body :global(ul),
  .hd-body :global(ol) {
    max-width: 720px;
    margin: 0 0 16px;
    padding-left: 22px;
  }
  .hd-body :global(li) {
    font-size: 17px;
    line-height: 1.7;
    margin-bottom: 6px;
  }
</style>
