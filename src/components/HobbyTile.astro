---
import type { CollectionEntry } from 'astro:content';

export interface Props {
  project: CollectionEntry<'hobby-projects'>;
  category: string;
  accent?: 'vermillion' | 'lime' | 'plum';
}

const { project, category, accent = 'vermillion' } = Astro.props;
const href = project.data.favorite ? `/hobbies/${category}/${project.id}` : null;
const Tag = href ? 'a' : 'div';
---

<Tag class={`hobby-tile hobby-tile--${accent}`} {...(href ? { href } : {})}>
  <div class="hobby-tile-media">
    <img
      src={project.data.cover}
      alt={project.data.title}
      loading="lazy"
      style={project.data.coverPosition ? `object-position: ${project.data.coverPosition}` : undefined}
    />
  </div>
  <div class="hobby-tile-body">
    <div class="hobby-tile-meta">
      <span class="hobby-tile-year">{project.data.year}</span>
    </div>
    <h3 class="hobby-tile-title">
      {project.data.title.split(' ').slice(0, -1).join(' ')}{' '}
      <span class={`hl hl--${accent} tilt-l`}>{project.data.title.split(' ').slice(-1)[0]}</span>
    </h3>
    <p class="hobby-tile-cap">{project.data.caption}</p>
    {href && <span class="hobby-tile-link">Read more →</span>}
  </div>
</Tag>

<style>
  .hobby-tile {
    display: grid;
    grid-template-columns: 1fr 1.4fr;
    gap: 36px;
    background: var(--card-dark-bg);
    color: var(--card-dark-text);
    border-radius: 18px;
    padding: 36px;
    transition: transform var(--dur-base) var(--ease-out);
  }
  @media (hover: hover) and (pointer: fine) {
    a.hobby-tile:hover { transform: translateY(-3px); }
  }
  a.hobby-tile:focus-visible { transform: translateY(-3px); }
  a.hobby-tile:active { transform: translateY(-1px) scale(0.99); }
  @media (max-width: 1024px) {
    .hobby-tile { grid-template-columns: 1fr; gap: 24px; padding: 28px; }
  }

  .hobby-tile-media {
    border-radius: 12px;
    overflow: hidden;
    border: 1.5px solid color-mix(in oklab, var(--card-dark-text) 18%, transparent);
  }
  .hobby-tile-media img {
    display: block;
    width: 100%;
    aspect-ratio: 4 / 3;
    object-fit: cover;
    /* Anchor crop at top so portrait-orientation photos keep heads / subject in frame */
    object-position: center top;
  }

  .hobby-tile-body {
    display: flex;
    flex-direction: column;
    gap: 14px;
    justify-content: center;
  }

  .hobby-tile-meta {
    display: flex;
    gap: 10px;
    align-items: center;
    font-family: var(--font-mono);
    font-size: 14px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: color-mix(in oklab, var(--card-dark-text) 60%, transparent);
  }
  .hobby-tile-fav {
    background: var(--lime);
    color: var(--text);
    padding: 3px 10px;
    border-radius: 3px;
    font-weight: 700;
    letter-spacing: 0.14em;
  }

  .hobby-tile-title {
    font-family: var(--font-display);
    font-weight: 800;
    font-size: clamp(28px, 3.4vw, 42px);
    line-height: 1;
    letter-spacing: -0.015em;
    text-transform: uppercase;
    color: var(--card-dark-text);
  }

  .hobby-tile-cap {
    font-family: var(--font-body);
    font-size: 16px;
    line-height: 1.65;
    color: color-mix(in oklab, var(--card-dark-text) 75%, transparent);
  }

  .hobby-tile-link {
    margin-top: auto;
    padding-top: 16px;
    font-family: var(--font-mono);
    font-size: 14px;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--vermillion);
  }
  .hobby-tile--lime .hobby-tile-link { color: var(--lime); }
  .hobby-tile--plum .hobby-tile-link { color: var(--tertiary-soft); }
</style>
