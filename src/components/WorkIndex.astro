---
import { getCollection } from 'astro:content';
import WorkCard from './WorkCard.astro';

// Reverse chronological: newest year first. order field is the tiebreaker when
// multiple case studies share a year.
const all = (await getCollection('case-studies')).sort(
  (a, b) => b.data.year - a.data.year || a.data.order - b.data.order
);
const total = all.length;
---

<section class="section">
  <div class="container">
    <div class="section-hdr">
      <span class="section-num">·</span>
      <h2>All <span class="hl hl--vermillion tilt-l">work samples</span>.</h2>
    </div>
    <p class="section-lead">
      Every project that earned a write-up. Problem, solution, outcome. Click any card for the full story.
    </p>

    <div class="work-search" data-work-search>
      <span class="work-search-sticker" aria-hidden="true">Search</span>

      <div class="work-search-field">
        <svg class="work-search-icon" width="22" height="22" viewBox="0 0 24 24" fill="none" aria-hidden="true">
          <circle cx="11" cy="11" r="7" stroke="currentColor" stroke-width="2.4"/>
          <path d="M21 21l-4.3-4.3" stroke="currentColor" stroke-width="2.4" stroke-linecap="round"/>
        </svg>
        <input
          type="search"
          id="work-search"
          class="work-search-input"
          placeholder="what kind of mess can I help with?"
          aria-label="Search work samples"
        />
        <button type="button" class="work-search-clear" data-work-search-clear aria-label="Clear search" hidden>×</button>
      </div>

      <div class="work-search-row">
        <div class="work-search-suggest">
          <span class="work-search-try">Try</span>
          <button type="button" class="work-search-chip" data-search-set="aws">AWS</button>
          <button type="button" class="work-search-chip" data-search-set="onboarding">Onboarding</button>
          <button type="button" class="work-search-chip" data-search-set="training">Training</button>
          <button type="button" class="work-search-chip" data-search-set="stakeholder">Stakeholders</button>
          <button type="button" class="work-search-chip" data-search-set="ai">AI</button>
        </div>
        <div class="work-search-meta">
          <span data-work-search-count>{total}</span> of <span>{total}</span>
        </div>
      </div>
    </div>

    <div class="work-list" data-work-list>
      {all.map((cs) => <WorkCard caseStudy={cs} />)}
    </div>

    <p class="work-empty" data-work-empty hidden>
      Nothing matches that. Try a broader term, or
      <button type="button" class="work-empty-link" data-work-search-clear>clear the search</button>.
    </p>
  </div>
</section>

<style>
  .work-list { display: flex; flex-direction: column; gap: 28px; }

  .section-hdr {
    display: flex; align-items: baseline; gap: 18px; margin-bottom: 28px;
  }
  .section-lead {
    max-width: 780px;
    font-size: 18px;
    color: var(--text-soft);
    line-height: 1.7;
    margin-bottom: 36px;
  }

  /* ---------------- Search block ---------------- */
  .work-search {
    position: relative;
    margin: 0 0 40px;
    padding-top: 22px;
  }

  .work-search-sticker {
    position: absolute;
    top: -4px;
    left: 26px;
    z-index: 2;
    background: var(--text);
    color: var(--bg);
    font-family: var(--font-display);
    font-weight: 800;
    font-size: 14px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    padding: 5px 14px;
    transform: rotate(-3deg);
    box-shadow: 3px 3px 0 0 var(--vermillion);
  }
  [data-theme="dark"] .work-search-sticker {
    box-shadow: 3px 3px 0 0 var(--vermillion);
  }

  .work-search-field {
    display: flex;
    align-items: center;
    gap: 12px;
    background: var(--surf);
    border: 2.5px solid var(--text);
    border-radius: 999px;
    padding: 4px 8px 4px 22px;
    transition: border-color var(--dur-base) var(--ease-out), box-shadow var(--dur-base) var(--ease-out), transform var(--dur-base) var(--ease-out);
  }
  .work-search-field:focus-within {
    border-color: var(--vermillion);
    box-shadow: 0 0 0 5px color-mix(in oklab, var(--vermillion) 24%, transparent);
    transform: translateY(-1px);
  }

  .work-search-icon { color: var(--vermillion); flex-shrink: 0; }

  .work-search-input {
    flex: 1;
    min-width: 0;
    border: 0;
    background: transparent;
    padding: 16px 4px;
    font-family: var(--font-body);
    font-size: 17px;
    color: var(--text);
    outline: none;
  }
  .work-search-input::placeholder {
    color: var(--text-soft);
    font-style: italic;
  }
  .work-search-input::-webkit-search-cancel-button { display: none; }

  .work-search-clear {
    width: 38px;
    height: 38px;
    flex-shrink: 0;
    border: 0;
    border-radius: 50%;
    background: var(--text);
    color: var(--bg);
    font-size: 22px;
    line-height: 1;
    cursor: pointer;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    transition: background var(--dur-fast) var(--ease-out), transform var(--dur-fast) var(--ease-out);
  }
  @media (hover: hover) and (pointer: fine) {
    .work-search-clear:hover { background: var(--vermillion); }
  }
  .work-search-clear:active { transform: scale(0.93); }

  .work-search-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 16px;
    margin-top: 16px;
    padding: 0 12px;
    flex-wrap: wrap;
  }

  .work-search-suggest {
    display: flex;
    gap: 8px;
    align-items: center;
    flex-wrap: wrap;
  }
  .work-search-try {
    font-family: var(--font-mono);
    font-size: 14px;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--text-soft);
    margin-right: 4px;
  }
  .work-search-chip {
    border: 1.5px solid color-mix(in oklab, var(--text) 22%, transparent);
    background: transparent;
    color: var(--text);
    font-family: var(--font-mono);
    font-size: 14px;
    font-weight: 600;
    letter-spacing: 0.06em;
    padding: 4px 12px;
    border-radius: 999px;
    cursor: pointer;
    transition: border-color var(--dur-fast) var(--ease-out), color var(--dur-fast) var(--ease-out), background var(--dur-fast) var(--ease-out), transform var(--dur-fast) var(--ease-out);
  }
  @media (hover: hover) and (pointer: fine) {
    .work-search-chip:hover {
      border-color: var(--vermillion);
      color: var(--vermillion);
      background: color-mix(in oklab, var(--vermillion) 8%, transparent);
    }
  }
  .work-search-chip:focus-visible {
    border-color: var(--vermillion);
    color: var(--vermillion);
    background: color-mix(in oklab, var(--vermillion) 8%, transparent);
  }
  .work-search-chip:active { transform: scale(0.97); }

  .work-search-meta {
    font-family: var(--font-mono);
    font-size: 14px;
    letter-spacing: 0.08em;
    color: var(--text-soft);
    white-space: nowrap;
  }
  .work-search-meta [data-work-search-count] { color: var(--text); font-weight: 600; }

  .work-empty {
    margin-top: 28px;
    padding: 32px 0;
    text-align: center;
    font-family: var(--font-serif);
    font-style: italic;
    font-size: 18px;
    color: var(--text-soft);
  }
  .work-empty-link {
    border: 0;
    background: transparent;
    color: var(--vermillion);
    font: inherit;
    text-decoration: underline;
    cursor: pointer;
    padding: 0;
  }
</style>

<script>
  const input  = document.getElementById('work-search') as HTMLInputElement | null;
  const list   = document.querySelector<HTMLElement>('[data-work-list]');
  const cards  = list ? Array.from(list.querySelectorAll<HTMLElement>('[data-work-card]')) : [];
  const count  = document.querySelector<HTMLElement>('[data-work-search-count]');
  const empty  = document.querySelector<HTMLElement>('[data-work-empty]');
  const clears = document.querySelectorAll<HTMLElement>('[data-work-search-clear]');
  const chips  = document.querySelectorAll<HTMLElement>('[data-search-set]');

  function apply(query: string) {
    const q = query.trim().toLowerCase();
    let visible = 0;
    cards.forEach((card) => {
      const haystack = card.dataset.search ?? '';
      const match = q === '' || haystack.includes(q);
      // Use inline style because .work-card has display: grid which overrides [hidden]
      card.style.display = match ? '' : 'none';
      if (match) visible++;
    });
    if (count) count.textContent = String(visible);
    if (empty) empty.hidden = visible !== 0;
    clears.forEach((btn) => { btn.hidden = q === ''; });
  }

  input?.addEventListener('input', (e) => apply((e.target as HTMLInputElement).value));

  clears.forEach((btn) => {
    btn.addEventListener('click', () => {
      if (input) input.value = '';
      apply('');
      input?.focus();
    });
  });

  chips.forEach((chip) => {
    chip.addEventListener('click', () => {
      if (!input) return;
      input.value = chip.dataset.searchSet ?? '';
      apply(input.value);
      input.focus();
    });
  });
</script>
