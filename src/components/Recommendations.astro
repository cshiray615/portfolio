---
// Anonymous testimonials carried over from the old portfolio. Attribution is by
// stakeholder role only — names redacted at the source.
const quotes = [
  {
    quote: `Casey is one of the best L&D professionals I've worked with, and one of the most consistent.`,
    role: 'Safety Stakeholder',
  },
  {
    quote: `Casey's superpower is adaptability. I have watched her dive into ambiguous situations and achieve a level of success that is admirable.`,
    role: 'Project Manager',
  },
];
---

<section class="section" id="recommendations">
  <div class="container">
    <div class="section-hdr">
      <span class="section-num">04</span>
      <h2>What people <span class="hl hl--lime tilt-r">say</span>.</h2>
    </div>

    <p class="section-lead">
      Selected recommendations from managers, peers, and stakeholders.
      More on <a href="https://linkedin.com/in/casey-shiray" target="_blank" rel="noopener">LinkedIn</a>.
    </p>

    <div class="rec-grid">
      {quotes.map((q) => (
        <figure class="rec-card">
          <span class="rec-mark" aria-hidden="true">“</span>
          <blockquote class="rec-text">{q.quote}</blockquote>
          <figcaption class="rec-role">{q.role}</figcaption>
        </figure>
      ))}
    </div>
  </div>
</section>

<style>
  .section-hdr { display: flex; align-items: baseline; gap: 18px; margin-bottom: 28px; }

  .section-lead {
    max-width: 780px;
    font-size: 18px;
    line-height: 1.7;
    color: var(--text);
    margin-bottom: 48px;
  }
  .section-lead a {
    color: var(--text);
    border-bottom: 1.5px solid color-mix(in oklab, var(--lime) 60%, transparent);
    transition: border-color 0.15s ease, color 0.15s ease;
  }
  .section-lead a:hover {
    color: var(--lime);
    border-bottom-color: var(--lime);
  }

  .rec-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    column-gap: 56px;
    row-gap: 64px;
  }
  @media (max-width: 900px) {
    .rec-grid { grid-template-columns: 1fr; row-gap: 56px; }
  }

  /* PullQuote-style: big display quotation mark, serif italic body, mono attribution.
     No card background or border — let the typography do the work. */
  .rec-card {
    position: relative;
    margin: 0;
    padding-left: 28px;
    display: flex;
    flex-direction: column;
    gap: 14px;
  }

  .rec-mark {
    position: absolute;
    left: -8px;
    top: -32px;
    font-family: var(--font-display);
    font-weight: 900;
    font-size: 92px;
    line-height: 1;
    color: var(--lime);
  }

  .rec-text {
    margin: 0;
    font-family: var(--font-serif);
    font-style: italic;
    font-size: clamp(18px, 1.8vw, 22px);
    line-height: 1.45;
    color: var(--text);
  }

  .rec-role {
    margin-top: 6px;
    font-family: var(--font-mono);
    font-size: 14px;
    font-weight: 600;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--text-soft);
  }
</style>
