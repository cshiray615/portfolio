---
import type { CollectionEntry } from 'astro:content';
import { getCollection, getEntry } from 'astro:content';

export interface Props {
  project: CollectionEntry<'hobby-projects'>;
}
const { project } = Astro.props;

const allProjects = await getCollection('hobby-projects');
const siblings = allProjects
  .filter((p) => p.data.category === project.data.category && p.data.favorite)
  .sort((a, b) => (a.data.order ?? 0) - (b.data.order ?? 0));

const currentIndex = siblings.findIndex((p) => p.id === project.id);
const prev = currentIndex > 0 ? siblings[currentIndex - 1] : null;
const next = currentIndex >= 0 && currentIndex < siblings.length - 1 ? siblings[currentIndex + 1] : null;

const category = await getEntry('hobby-categories', project.data.category);
const accent: 'vermillion' | 'lime' | 'plum' = category?.data.accent ?? 'vermillion';
const categoryName = category?.data.name ?? project.data.category;
---

{(prev || next) && (
  <nav class="cs-nav" aria-label="Hobby project navigation">
    <div class="container cs-nav-grid">
      {prev ? (
        <a class={`cs-nav-card cs-nav-card--prev cs-nav-card--${accent}`} href={`/hobbies/${prev.data.category}/${prev.id}`}>
          <div class="cs-nav-row">
            <div class="cs-nav-eyebrow">← Previous project</div>
            <div class="cs-nav-title">{prev.data.title}</div>
            <div class="cs-nav-tag">{categoryName} · {prev.data.year}</div>
          </div>
        </a>
      ) : (
        <div class="cs-nav-card cs-nav-card--empty" aria-hidden="true"></div>
      )}

      {next ? (
        <a class={`cs-nav-card cs-nav-card--next cs-nav-card--${accent}`} href={`/hobbies/${next.data.category}/${next.id}`}>
          <div class="cs-nav-row">
            <div class="cs-nav-eyebrow">Next project →</div>
            <div class="cs-nav-title">{next.data.title}</div>
            <div class="cs-nav-tag">{categoryName} · {next.data.year}</div>
          </div>
        </a>
      ) : (
        <div class="cs-nav-card cs-nav-card--empty" aria-hidden="true"></div>
      )}
    </div>
  </nav>
)}

<style>
  .cs-nav {
    background: var(--card-dark-bg);
    color: var(--card-dark-text);
    margin-top: 64px;
  }
  .cs-nav-grid {
    display: grid;
    grid-template-columns: 1fr 2.4fr;
    gap: 1px;
    background: color-mix(in oklab, var(--card-dark-text) 18%, transparent);
    padding: 0;
  }
  @media (max-width: 720px) {
    .cs-nav-grid { grid-template-columns: 1fr; }
  }

  .cs-nav-card {
    display: flex;
    flex-direction: column;
    gap: 10px;
    background: var(--card-dark-bg);
    color: var(--card-dark-text);
    text-decoration: none;
    transition: background 0.3s ease;
  }
  .cs-nav-card--next {
    padding: 56px 32px;
    text-align: left;
    align-items: flex-start;
  }
  .cs-nav-card--prev {
    padding: 28px 24px;
    text-align: left;
    align-items: flex-start;
    justify-content: center;
    gap: 6px;
  }

  .cs-nav-card--empty { padding: 0; background: transparent; }

  a.cs-nav-card:hover,
  a.cs-nav-card:focus-visible {
    background: color-mix(in oklab, var(--card-dark-bg) 88%, var(--card-dark-text));
  }

  .cs-nav-eyebrow {
    font-family: var(--font-mono);
    font-weight: 700;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--vermillion);
  }
  .cs-nav-card--next .cs-nav-eyebrow { font-size: 14px; }
  .cs-nav-card--prev .cs-nav-eyebrow { font-size: 14px; opacity: 0.85; }
  .cs-nav-card--lime .cs-nav-eyebrow { color: var(--lime); }
  .cs-nav-card--plum .cs-nav-eyebrow { color: var(--tertiary-soft); }

  .cs-nav-title {
    font-family: var(--font-display);
    font-weight: 800;
    line-height: 1;
    text-transform: uppercase;
    letter-spacing: -0.02em;
  }
  .cs-nav-card--next .cs-nav-title { font-size: clamp(28px, 4vw, 48px); }
  .cs-nav-card--prev .cs-nav-title { font-size: clamp(15px, 1.6vw, 18px); letter-spacing: -0.01em; }

  .cs-nav-tag {
    font-family: var(--font-mono);
    letter-spacing: 0.1em;
    color: color-mix(in oklab, var(--card-dark-text) 60%, transparent);
  }
  .cs-nav-card--next .cs-nav-tag { font-size: 14px; }
  .cs-nav-card--prev .cs-nav-tag { font-size: 14px; }
</style>
