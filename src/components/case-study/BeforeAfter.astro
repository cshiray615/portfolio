---
export interface Side {
  src: string;
  alt?: string;
  bg?: string;
}
export interface Props {
  before: Side;
  after: Side;
  caption?: string;
  ratio?: string;        // e.g. "16/9" (default), "4/3", "3/2"
  beforeLabel?: string;  // override the "BEFORE" tag text
  afterLabel?: string;   // override the "AFTER" tag text
}
const {
  before,
  after,
  caption,
  ratio = '16/9',
  beforeLabel = 'Before',
  afterLabel = 'After',
} = Astro.props;
---

<figure class="cs-ba">
  <div
    class="cs-ba-slider"
    data-ba-slider
    style={`--ba-pos:50%; --ba-ratio:${ratio};`}
  >
    <div class="cs-ba-img cs-ba-img--after" style={after.bg ? `background:${after.bg}` : undefined}>
      <img src={after.src} alt={after.alt ?? 'After'} loading="lazy" draggable="false" />
    </div>
    <div class="cs-ba-img cs-ba-img--before" style={before.bg ? `background:${before.bg}` : undefined}>
      <img src={before.src} alt={before.alt ?? 'Before'} loading="lazy" draggable="false" />
    </div>

    <span class="cs-ba-tag cs-ba-tag--before">{beforeLabel}</span>
    <span class="cs-ba-tag cs-ba-tag--after">{afterLabel}</span>

    <div class="cs-ba-line" aria-hidden="true"></div>
    <button
      type="button"
      class="cs-ba-handle"
      data-ba-handle
      role="slider"
      aria-label="Drag to compare before and after"
      aria-valuemin="0"
      aria-valuemax="100"
      aria-valuenow="50"
    >
      <svg width="18" height="18" viewBox="0 0 24 24" aria-hidden="true">
        <path d="M9 6l-6 6 6 6M15 6l6 6-6 6" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
    </button>
  </div>
  {caption && <figcaption>{caption}</figcaption>}
</figure>

<style>
  .cs-ba {
    margin: 40px 0;
  }

  .cs-ba-slider {
    position: relative;
    width: 100%;
    aspect-ratio: var(--ba-ratio, 16 / 9);
    border-radius: 12px;
    border: 1.5px solid var(--divider);
    overflow: hidden;
    touch-action: none;
    user-select: none;
    background: var(--surf);
  }

  .cs-ba-img {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .cs-ba-img img {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: contain;
    pointer-events: none;
  }
  .cs-ba-img--before {
    clip-path: inset(0 calc(100% - var(--ba-pos)) 0 0);
  }

  .cs-ba-tag {
    position: absolute;
    top: 12px;
    font-family: var(--font-mono);
    font-size: 14px;
    font-weight: 700;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    padding: 5px 10px;
    border-radius: 4px;
    border: 1.5px solid var(--text);
    pointer-events: none;
  }
  .cs-ba-tag--before { left: 12px;  background: var(--vermillion); color: var(--bg); }
  .cs-ba-tag--after  { right: 12px; background: var(--lime);       color: var(--text); }

  .cs-ba-line {
    position: absolute;
    top: 0;
    bottom: 0;
    left: var(--ba-pos);
    width: 3px;
    margin-left: -1.5px;
    background: var(--bg);
    box-shadow: 0 0 0 1px rgba(0, 0, 0, 0.25);
    pointer-events: none;
  }

  .cs-ba-handle {
    position: absolute;
    top: 50%;
    left: var(--ba-pos);
    width: 44px;
    height: 44px;
    margin: -22px 0 0 -22px;
    border: 0;
    padding: 0;
    border-radius: 50%;
    background: var(--vermillion);
    color: var(--bg);
    cursor: ew-resize;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    box-shadow: 0 6px 18px rgba(0, 0, 0, 0.28);
    transition: transform var(--dur-fast) var(--ease-out);
  }
  @media (hover: hover) and (pointer: fine) {
    .cs-ba-handle:hover { transform: scale(1.08); }
  }
  .cs-ba-handle:focus-visible { transform: scale(1.08); }
  .cs-ba-handle:active { transform: scale(0.96); }
  .cs-ba-handle:focus-visible { outline: 2px solid var(--text); outline-offset: 3px; }

  .cs-ba figcaption {
    margin-top: 16px;
    font-family: var(--font-serif);
    font-style: italic;
    font-size: 16px;
    line-height: 1.65;
    color: var(--text-soft);
    max-width: 720px;
  }
</style>

<script>
  function setPos(slider: HTMLElement, pct: number) {
    const clamped = Math.max(0, Math.min(100, pct));
    slider.style.setProperty('--ba-pos', clamped + '%');
    const handle = slider.querySelector<HTMLButtonElement>('[data-ba-handle]');
    handle?.setAttribute('aria-valuenow', String(Math.round(clamped)));
  }
  function pctFromEvent(slider: HTMLElement, clientX: number): number {
    const rect = slider.getBoundingClientRect();
    return ((clientX - rect.left) / rect.width) * 100;
  }

  document.querySelectorAll<HTMLElement>('[data-ba-slider]').forEach((slider) => {
    let dragging = false;
    let pointerId: number | null = null;

    const onDown = (e: PointerEvent) => {
      dragging = true;
      pointerId = e.pointerId;
      slider.setPointerCapture(e.pointerId);
      setPos(slider, pctFromEvent(slider, e.clientX));
      e.preventDefault();
    };
    const onMove = (e: PointerEvent) => {
      if (!dragging) return;
      setPos(slider, pctFromEvent(slider, e.clientX));
    };
    const onUp = (e: PointerEvent) => {
      if (pointerId !== null) slider.releasePointerCapture(pointerId);
      dragging = false;
      pointerId = null;
    };

    slider.addEventListener('pointerdown', onDown);
    slider.addEventListener('pointermove', onMove);
    slider.addEventListener('pointerup', onUp);
    slider.addEventListener('pointercancel', onUp);

    const handle = slider.querySelector<HTMLButtonElement>('[data-ba-handle]');
    handle?.addEventListener('keydown', (e) => {
      const current = parseFloat(slider.style.getPropertyValue('--ba-pos')) || 50;
      const step = e.shiftKey ? 10 : 5;
      let next = current;
      if (e.key === 'ArrowLeft')  next = current - step;
      else if (e.key === 'ArrowRight') next = current + step;
      else if (e.key === 'Home')  next = 0;
      else if (e.key === 'End')   next = 100;
      else return;
      setPos(slider, next);
      e.preventDefault();
    });
  });
</script>
