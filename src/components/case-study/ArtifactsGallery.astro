---
export interface Props {
  images: Array<{ src: string; caption?: string; alt?: string; bg?: string }>;
}
const { images } = Astro.props;
---

<section class="cs-gallery">
  <div class="container">
    <div class="gallery-grid">
      {images.map((img) => (
        <figure class="gallery-item">
          <button
            type="button"
            class="gallery-trigger"
            data-lightbox-trigger
            data-src={img.src}
            data-caption={img.caption ?? ''}
            data-alt={img.alt ?? img.caption ?? ''}
            style={img.bg ? `background:${img.bg}` : undefined}
            aria-label={`Open ${img.alt ?? img.caption ?? 'image'} full size`}
          >
            <img src={img.src} alt={img.alt ?? img.caption ?? ''} loading="lazy" />
          </button>
          {img.caption && <figcaption>{img.caption}</figcaption>}
        </figure>
      ))}
    </div>
  </div>
</section>

<style>
  .cs-gallery { padding: 48px 0; }
  .gallery-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 16px;
  }
  .gallery-item { display: flex; flex-direction: column; gap: 8px; margin: 0; }

  .gallery-trigger {
    display: block;
    width: 100%;
    padding: 0;
    background: var(--surf);
    border: 1.5px solid var(--divider);
    border-radius: 12px;
    cursor: zoom-in;
    overflow: hidden;
    transition: transform 0.2s ease;
  }
  .gallery-trigger:hover,
  .gallery-trigger:focus-visible { transform: translateY(-3px); }

  .gallery-trigger img {
    display: block;
    width: 100%;
    aspect-ratio: 4 / 3;
    object-fit: contain;
  }

  figcaption {
    font-family: var(--font-mono);
    font-size: 14px;
    letter-spacing: 0.1em;
    color: var(--text-soft);
  }
</style>
