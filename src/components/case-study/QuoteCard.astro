---
// A poster-style quote card, matching the Instagram carousel cards:
// lime mono eyebrow, big League Spartan headline with a vermillion marker
// highlight, a serif-italic quote, a Caveat handwritten aside, and a
// caseyshiray.com / index footer. Always renders as a dark poster so it pops
// on the cream light theme and sits a touch above the near-black dark theme.
export interface Props {
  eyebrow?: string;
  headline: string;
  mark?: string;                        // phrase within headline to highlight
  markStyle?: 'box' | 'strike';         // vermillion knockout box (default) or strike-through bar
  quote?: string;
  aside?: string;                       // handwritten lavender line
}
const {
  eyebrow,
  headline,
  mark,
  markStyle = 'box',
  quote,
  aside,
} = Astro.props;

// Split the headline into [before, highlighted phrase, after].
const i = mark ? headline.indexOf(mark) : -1;
const hasMark = mark != null && i !== -1;
const before = hasMark ? headline.slice(0, i) : headline;
const match = hasMark ? mark : '';
const after = hasMark ? headline.slice(i + (mark as string).length) : '';
---

<figure class="qc-outer">
  <div class="container">
    <div class="qc-card">
      {eyebrow && <p class="qc-eyebrow">{eyebrow}</p>}

      <h2 class="qc-headline">
        {before}<span class={`qc-mark qc-mark--${markStyle}`}>{match}</span>{after}
      </h2>

      {quote && <blockquote class="qc-quote">{quote}</blockquote>}

      {aside && <p class="qc-aside">{aside}</p>}
    </div>
  </div>
</figure>

<style>
  .qc-outer { margin: 56px 0; }

  .qc-card {
    position: relative;
    max-width: 840px;
    padding: clamp(32px, 5vw, 56px);
    background: #201A28;                       /* deep plum-charcoal poster */
    color: #FAF3E0;                            /* cream */
    border: 1.5px solid rgba(250, 243, 224, 0.14);
    border-radius: 18px;
    overflow: hidden;
    box-shadow: 0 16px 48px rgba(0, 0, 0, 0.22);
  }
  /* Warm glow, top-right — matches the cards */
  .qc-card::before {
    content: "";
    position: absolute;
    inset: 0;
    border-radius: inherit;
    pointer-events: none;
    background: radial-gradient(115% 85% at 88% 6%, rgba(255, 94, 58, 0.16), transparent 55%);
  }
  .qc-card > * { position: relative; }

  .qc-eyebrow {
    font-family: var(--font-mono);
    font-size: 14px;
    font-weight: 700;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--lime);
    margin-bottom: 22px;
  }

  .qc-headline {
    font-family: var(--font-display);
    font-weight: 900;
    text-transform: uppercase;
    font-size: clamp(34px, 5.6vw, 60px);
    line-height: 0.96;
    letter-spacing: -0.01em;
    color: #FAF3E0;
  }

  /* Vermillion knockout box */
  .qc-mark--box {
    background: var(--vermillion);
    color: #201A28;
    padding: 0.02em 0.14em;
    -webkit-box-decoration-break: clone;
    box-decoration-break: clone;
  }
  /* Vermillion strike-through bar */
  .qc-mark--strike {
    position: relative;
    color: inherit;
    white-space: nowrap;
  }
  .qc-mark--strike::after {
    content: "";
    position: absolute;
    left: -1%;
    right: -1%;
    top: 46%;
    height: 0.16em;
    background: var(--vermillion);
    transform: rotate(-1.5deg);
    pointer-events: none;
  }

  .qc-quote {
    margin: 28px 0 0;
    font-family: var(--font-serif);
    font-style: italic;
    font-size: clamp(16px, 1.9vw, 20px);
    line-height: 1.6;
    color: rgba(250, 243, 224, 0.9);
    max-width: 54ch;
  }
  /* typographic quotes around the serif quote */
  .qc-quote::before { content: "\201C"; }
  .qc-quote::after  { content: "\201D"; }

  .qc-aside {
    margin: 26px 0 0;
    font-family: var(--font-hand);
    font-weight: 600;
    font-size: clamp(22px, 2.8vw, 30px);
    line-height: 1.25;
    color: var(--lavender);
  }

</style>
