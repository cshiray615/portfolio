---
import type { CollectionEntry } from 'astro:content';

export interface Props {
  caseStudy: CollectionEntry<'case-studies'>;
}

const { caseStudy } = Astro.props;
const { data } = caseStudy;
const titleWords = data.title.split(' ');
const last = titleWords.pop() ?? data.title;
const rest = titleWords.join(' ');

const quote = data.coverQuote;

function highlightSplit(text: string, word?: string): string[] {
  if (!word) return [text];
  const escaped = word.replace(/[.*+?^${}()|[\]\\]/g, '\\$&');
  const re = new RegExp(`(\\b${escaped}\\b)`, 'gi');
  return text.split(re).filter((part) => part !== '');
}

function isHighlight(part: string, word?: string): boolean {
  return !!word && part.toLowerCase() === word.toLowerCase();
}
---

<header class="cs-hero">
  <div class="container">
    <div class="cs-breadcrumb">
      <a href="/work">← Work Samples</a>
    </div>

    <div class="eyebrow" style="margin-bottom: 14px;">
      {data.tag} · {data.year}
    </div>

    <h1 class="cs-h1">
      {rest}{' '}
      <span class={`hl hl--${data.accent} tilt-l`}>{last}</span>
    </h1>

    {data.tagline && <p class="cs-tagline">{data.tagline}</p>}

    <div class="cs-meta">
      <div><strong>Role</strong>{data.role}</div>
      <div><strong>Year</strong>{data.year}</div>
      <div><strong>Client</strong>{data.client}</div>
    </div>

    {data.cover && (
      <figure class={`cs-cover ${quote ? 'cs-cover--with-quote' : ''}`}>
        <button
          type="button"
          class="cs-cover-trigger"
          data-lightbox-trigger
          data-src={data.cover}
          data-caption={quote ? [...quote.lines, quote.coda].filter(Boolean).join(' ') : (data.tagline ?? data.title)}
          data-alt={data.title}
          style={data.coverBg ? `background:${data.coverBg}` : undefined}
          aria-label={`Open ${data.title} full size`}
        >
          <img src={data.cover} alt={data.title} loading="eager" />
          {quote && (
            <>
              <span class="cs-cover-gradient" aria-hidden="true"></span>
              <blockquote class={`cs-cover-quote cs-cover-quote--${data.accent}`}>
                <span class="cs-cover-quote-mark" aria-hidden="true">“</span>
                <span class="cs-cover-quote-lines">
                  {quote.lines.map((line) => (
                    <span class="cs-cover-quote-line">
                      {highlightSplit(line, quote.highlight).map((part) =>
                        isHighlight(part, quote.highlight)
                          ? <strong class="cs-cover-quote-emph">{part}</strong>
                          : part
                      )}
                    </span>
                  ))}
                </span>
                {quote.coda && (
                  <span class="cs-cover-quote-coda">
                    {highlightSplit(quote.coda, quote.highlight).map((part) =>
                      isHighlight(part, quote.highlight)
                        ? <strong class="cs-cover-quote-emph">{part}</strong>
                        : part
                    )}
                  </span>
                )}
              </blockquote>
            </>
          )}
        </button>
      </figure>
    )}
  </div>
</header>

<style>
  .cs-hero { padding: 80px 0 48px; }
  .cs-breadcrumb {
    font-family: var(--font-mono);
    font-size: 14px;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    margin-bottom: 28px;
    display: inline-flex; gap: 8px; align-items: center;
  }
  .cs-breadcrumb a { color: var(--text-soft); }
  .cs-breadcrumb a:hover { color: var(--text); }

  .cs-h1 { font-size: clamp(48px, 7vw, 84px); line-height: 0.92; max-width: 1000px; }
  .cs-tagline {
    margin-top: 28px;
    font-family: var(--font-serif);
    font-style: italic;
    font-size: clamp(22px, 2.4vw, 30px);
    line-height: 1.35;
    color: var(--text);
    max-width: 760px;
  }
  .cs-meta {
    margin-top: 40px;
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
    padding: 24px 0;
    border-top: 1.5px solid var(--divider);
    border-bottom: 1.5px solid var(--divider);
  }
  @media (max-width: 640px) { .cs-meta { grid-template-columns: 1fr; gap: 16px; } }
  .cs-meta > div { font-family: var(--font-mono); font-size: 13px; }
  .cs-meta strong {
    display: block;
    font-size: 14px;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--text-soft);
    margin-bottom: 4px;
    font-weight: 600;
  }

  .cs-cover {
    margin: 48px 0 0;
  }
  .cs-cover-trigger {
    display: block;
    width: 100%;
    padding: 0;
    background: var(--surf);
    border-radius: 16px;
    border: 1.5px solid var(--divider);
    overflow: hidden;
    cursor: zoom-in;
    transition: transform 0.25s ease;
  }
  .cs-cover-trigger:hover,
  .cs-cover-trigger:focus-visible { transform: translateY(-3px); }
  .cs-cover img {
    display: block;
    width: 100%;
    height: auto;
  }

  /* Cover quote overlay — poster stack */
  .cs-cover--with-quote .cs-cover-trigger { position: relative; cursor: default; }
  .cs-cover--with-quote .cs-cover-trigger:hover,
  .cs-cover--with-quote .cs-cover-trigger:focus-visible { transform: none; }
  .cs-cover-gradient {
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg,
      rgba(28, 24, 32, 0) 28%,
      rgba(28, 24, 32, 0.55) 64%,
      rgba(28, 24, 32, 0.94) 100%);
    pointer-events: none;
  }
  .cs-cover-quote {
    position: absolute;
    left: clamp(24px, 5%, 64px);
    right: clamp(24px, 5%, 64px);
    bottom: clamp(28px, 4%, 56px);
    margin: 0;
    color: #FAF3E0;
    text-shadow: 0 2px 18px rgba(0, 0, 0, 0.55);
    max-width: 920px;
    display: flex;
    flex-direction: column;
    gap: 0;
    text-align: left;
  }
  .cs-cover-quote-mark {
    font-family: var(--font-display);
    font-weight: 900;
    font-size: clamp(60px, 8.5vw, 120px);
    line-height: 0.55;
    margin-bottom: 0.18em;
    color: var(--vermillion);
    text-shadow: 0 4px 22px rgba(0, 0, 0, 0.5);
  }
  .cs-cover-quote--lime .cs-cover-quote-mark { color: var(--lime); }
  .cs-cover-quote--plum .cs-cover-quote-mark { color: var(--lavender); }

  .cs-cover-quote-lines {
    display: flex;
    flex-direction: column;
    font-family: var(--font-display);
    font-weight: 900;
    font-size: clamp(30px, 5.2vw, 64px);
    line-height: 1;
    letter-spacing: -0.01em;
    text-transform: uppercase;
  }
  .cs-cover-quote-line {
    display: block;
    padding-block: 0.02em;
  }
  .cs-cover-quote-coda {
    display: block;
    margin-top: 0.5em;
    padding-top: 0.2em;
    font-family: var(--font-serif);
    font-style: italic;
    font-weight: 400;
    font-size: clamp(18px, 2.4vw, 28px);
    line-height: 1.35;
    letter-spacing: 0;
    text-transform: none;
  }
  /* Emphasized word inside the cover quote: accent color + bold, inherits italic from coda */
  .cs-cover-quote-emph {
    font-weight: 800;
    font-style: inherit;
    color: var(--vermillion);
  }
  .cs-cover-quote--lime .cs-cover-quote-emph { color: var(--lime); }
  .cs-cover-quote--plum .cs-cover-quote-emph { color: var(--lavender); }

  @media (max-width: 640px) {
    .cs-cover-gradient {
      background: linear-gradient(180deg,
        rgba(28, 24, 32, 0) 12%,
        rgba(28, 24, 32, 0.7) 50%,
        rgba(28, 24, 32, 0.96) 100%);
    }
    .cs-cover-quote { gap: 0; }
  }
</style>
