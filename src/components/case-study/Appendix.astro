---
export interface Props {
  title: string;
  open?: boolean;       // start expanded? default false
}
const { title, open = false } = Astro.props;
---

<details class="cs-appendix" open={open}>
  <summary class="cs-appendix-summary">
    <span class="cs-appendix-tag">Appendix</span>
    <span class="cs-appendix-title">{title}</span>
    <span class="cs-appendix-chevron" aria-hidden="true">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none">
        <path d="M6 9l6 6 6-6" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
    </span>
  </summary>
  <div class="cs-appendix-body"><slot /></div>
</details>

<style>
  .cs-appendix {
    margin: 32px 0;
    max-width: 720px;
    border: 1.5px solid var(--divider);
    border-radius: 12px;
    background: color-mix(in oklab, var(--text) 3%, var(--bg));
  }

  .cs-appendix-summary {
    list-style: none;
    cursor: pointer;
    padding: 18px 22px;
    display: flex;
    align-items: center;
    gap: 14px;
    user-select: none;
  }
  .cs-appendix-summary::-webkit-details-marker { display: none; }
  .cs-appendix-summary:hover { background: color-mix(in oklab, var(--text) 5%, var(--bg)); }

  .cs-appendix-tag {
    font-family: var(--font-mono);
    font-size: 14px;
    font-weight: 700;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--vermillion);
    flex-shrink: 0;
  }

  .cs-appendix-title {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 16px;
    letter-spacing: -0.005em;
    color: var(--text);
    flex: 1;
    text-transform: none;
  }

  .cs-appendix-chevron {
    color: var(--text-soft);
    display: inline-flex;
    align-items: center;
    transition: transform 0.2s ease;
    flex-shrink: 0;
  }
  .cs-appendix[open] .cs-appendix-chevron { transform: rotate(180deg); }

  .cs-appendix-body {
    padding: 4px 22px 22px;
    font-family: var(--font-body);
    font-size: 15px;
    line-height: 1.7;
    color: var(--text);
    border-top: 1px solid var(--divider);
    margin-top: 0;
    padding-top: 18px;
  }
  .cs-appendix-body :global(p) { margin: 0 0 14px; }
  .cs-appendix-body :global(p:last-child) { margin-bottom: 0; }
  .cs-appendix-body :global(strong) { font-weight: 700; }
  .cs-appendix-body :global(em) { font-family: var(--font-serif); font-style: italic; }
  .cs-appendix-body :global(ul),
  .cs-appendix-body :global(ol) { padding-left: 22px; margin: 0 0 14px; }
  .cs-appendix-body :global(li) { margin-bottom: 6px; }
  .cs-appendix-body :global(code) {
    font-family: var(--font-mono);
    font-size: 0.92em;
    background: color-mix(in oklab, var(--text) 10%, var(--bg));
    padding: 2px 6px;
    border-radius: 4px;
  }
</style>
