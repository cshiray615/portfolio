---
import type { CollectionEntry } from 'astro:content';

export interface Props {
  caseStudy: CollectionEntry<'case-studies'>;
}

const { caseStudy } = Astro.props;
const { data, id } = caseStudy;
const href = `/work/${id}`;

// Split the title into [before, highlighted phrase, after]. When `highlight`
// is set and found in the title, that phrase is emphasized; otherwise the
// last word is (the original behavior).
function splitTitle(title: string, phrase?: string) {
  const i = phrase ? title.indexOf(phrase) : -1;
  if (phrase && i !== -1) {
    return { before: title.slice(0, i), match: phrase, after: title.slice(i + phrase.length) };
  }
  const words = title.split(' ');
  const match = words.pop() ?? title;
  return { before: words.length ? words.join(' ') + ' ' : '', match, after: '' };
}
const { before, match, after } = splitTitle(data.title, data.highlight);

// Concatenate searchable text (lowercased, HTML stripped) for client-side filter.
const stripHtml = (s: string) => s.replace(/<[^>]+>/g, '');
const searchText = [
  data.title,
  data.tagline ?? '',
  data.tag,
  data.client,
  String(data.year),
  data.stack.join(' '),
  stripHtml(data.summary.problem),
  stripHtml(data.summary.outcome),
].join(' ').toLowerCase();
---

<a class={`work-card work-card--${data.accent}`} href={href} data-work-card data-search={searchText}>
  <div class="work-meta">
    <div class="work-tag">{data.tag}</div>
    <h3 class="work-title">
      {before}<span class={`hl hl--${data.accent} tilt-l`}>{match}</span>{after}
    </h3>
    <div class="work-stack">
      {data.stack.map((s) => <span class="chip">{s}</span>)}
    </div>
  </div>
  <div class="work-body">
    <div class="row row--prob">
      <span class="label label--prob">Problem</span>
      <span class="txt" set:html={data.summary.problem} />
    </div>
    <div class="row row--out">
      <span class="label label--out">Outcome</span>
      <span class="txt" set:html={data.summary.outcome} />
    </div>
    <span class="work-link">Read the case study →</span>
  </div>
</a>

<style>
  .work-card {
    display: grid;
    grid-template-columns: 1fr 1.4fr;
    gap: 36px;
    background: var(--card-dark-bg);
    color: var(--card-dark-text);
    border-radius: 18px;
    padding: 36px;
    transition: transform var(--dur-base) var(--ease-out);
  }
  @media (hover: hover) and (pointer: fine) {
    .work-card:hover { transform: translateY(-3px); }
  }
  .work-card:focus-visible { transform: translateY(-3px); }
  .work-card:active { transform: translateY(-1px) scale(0.99); }
  @media (max-width: 1024px) {
    .work-card { grid-template-columns: 1fr; gap: 24px; padding: 28px; }
  }

  .work-meta { display: flex; flex-direction: column; gap: 12px; }
  .work-tag {
    font-family: var(--font-mono);
    font-size: 14px;
    font-weight: 600;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--vermillion);
  }
  .work-card--lime .work-tag       { color: var(--lime); }
  .work-card--plum .work-tag       { color: var(--tertiary-soft); }

  .work-title {
    font-family: var(--font-display);
    font-weight: 800;
    font-size: clamp(28px, 3.4vw, 42px);
    line-height: 1;
    letter-spacing: -0.015em;
    text-transform: uppercase;
    color: var(--card-dark-text);
  }
  .work-stack { display: flex; flex-wrap: wrap; gap: 8px; margin-top: 4px; }
  .chip {
    font-family: var(--font-mono);
    font-size: 14px;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    padding: 4px 10px;
    border-radius: 3px;
    border: 1px solid color-mix(in oklab, var(--card-dark-text) 30%, transparent);
    color: color-mix(in oklab, var(--card-dark-text) 70%, transparent);
  }

  .work-body { display: flex; flex-direction: column; gap: 16px; }
  .row { display: flex; gap: 14px; align-items: flex-start; }
  .label {
    flex: 0 0 80px;
    font-family: var(--font-mono);
    font-size: 14px;
    font-weight: 700;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    padding-top: 2px;
  }
  .label--prob { color: var(--vermillion); }
  .label--out  { color: var(--tertiary-soft); }
  .txt {
    font-family: var(--font-body);
    font-size: 14px;
    line-height: 1.65;
    color: var(--card-dark-text);
    flex: 1;
  }
  .row--prob .txt { color: color-mix(in oklab, var(--card-dark-text) 70%, transparent); }
  .row--out :global(b) { color: var(--tertiary-soft); font-weight: 700; }
  .work-link {
    margin-top: auto;
    padding-top: 16px;
    font-family: var(--font-mono);
    font-size: 14px;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--vermillion);
  }
  .work-card--lime .work-link { color: var(--lime); }
  .work-card--plum .work-link { color: var(--tertiary-soft); }
  /* .hl--plum keeps its global plum+cream coloring on the ink/cream card surface — no override needed. */
</style>
