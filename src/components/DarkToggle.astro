---
// Floating sun/moon button pinned to the bottom-right of every page.
// Renders the icon for the *current* theme; flips on click. CSS uses [data-theme] to swap icons.
---

<button
  class="dark-toggle"
  id="dark-toggle"
  type="button"
  aria-label="Toggle dark mode"
  aria-pressed="false"
>
  <svg class="icon icon--sun" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
    <circle cx="12" cy="12" r="4"/>
    <path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M4.93 19.07l1.41-1.41M17.66 6.34l1.41-1.41"/>
  </svg>
  <svg class="icon icon--moon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
    <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
  </svg>
</button>

<style>
  .dark-toggle {
    position: fixed;
    right: 22px;
    bottom: 22px;
    z-index: 90;
    width: 44px;
    height: 44px;
    border-radius: 999px;
    border: 1.5px solid var(--divider);
    background: var(--surf);
    color: var(--text);
    display: inline-flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    box-shadow: 0 4px 14px rgba(0, 0, 0, 0.12);
    transition: background 0.15s ease, transform 0.15s ease, box-shadow 0.2s ease;
  }
  .dark-toggle:hover,
  .dark-toggle:focus-visible {
    transform: translateY(-2px);
    box-shadow: 0 8px 22px rgba(0, 0, 0, 0.18);
  }
  [data-theme="dark"] .dark-toggle {
    box-shadow: 0 4px 14px rgba(0, 0, 0, 0.4);
  }
  [data-theme="dark"] .dark-toggle:hover,
  [data-theme="dark"] .dark-toggle:focus-visible {
    box-shadow: 0 8px 22px rgba(0, 0, 0, 0.5);
  }

  .icon { display: block; }
  /* Show the destination icon: moon on light pages (click → dark), sun on dark pages (click → light) */
  .icon--sun  { display: none; }
  [data-theme="dark"] .icon--moon { display: none; }
  [data-theme="dark"] .icon--sun  { display: block; }

  @media (max-width: 640px) {
    .dark-toggle { right: 18px; bottom: 18px; width: 42px; height: 42px; }
  }
</style>

<script>
  import { toggleTheme } from '~/lib/theme-init';

  const btn = document.getElementById('dark-toggle');

  function syncPressed() {
    if (!btn) return;
    const isDark = document.documentElement.dataset.theme === 'dark';
    btn.setAttribute('aria-pressed', isDark ? 'true' : 'false');
  }
  syncPressed();

  btn?.addEventListener('click', () => {
    toggleTheme();
    syncPressed();
  });
</script>
