---
---

<section class="closing section">
  <div class="container">
    <h2 class="closing-h">
      Got a <span class="hl hl--vermillion tilt-l">training emergency</span> on your plate?
    </h2>
    <p class="closing-sub">Let's figure out if training is actually the answer — together.</p>
    <div class="closing-actions">
      <button class="cta cta--primary" type="button" data-copy-email data-email="casey@caseyshiray.com">Email Casey</button>
      <a class="cta cta--ghost" href="/about">More about Casey</a>
    </div>
  </div>
</section>

<style>
  .closing { padding: 120px 0; text-align: center; }
  .closing-h {
    font-size: clamp(40px, 6vw, 84px);
    line-height: 0.95;
  }
  .closing-sub {
    margin-top: 20px;
    font-family: var(--font-hand);
    font-size: clamp(28px, 3vw, 38px);
    color: var(--tertiary-loud);
  }
  .closing-actions {
    margin-top: 40px;
    display: flex;
    justify-content: center;
    gap: 14px;
    flex-wrap: wrap;
  }
  .cta {
    font: inherit;
    font-family: var(--font-mono);
    font-size: 13px;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    padding: 16px 28px;
    border-radius: 8px;
    cursor: pointer;
    transition: transform var(--dur-fast) var(--ease-out), border-color var(--dur-fast) var(--ease-out), filter var(--dur-fast) var(--ease-out);
  }
  button.cta { border: 0; }
  .cta:active { transform: scale(0.97); }
  .cta--primary { background: var(--vermillion); color: var(--bg); }
  .cta--ghost { background: transparent; border: 1.5px solid var(--divider); color: var(--text); }
  @media (hover: hover) and (pointer: fine) {
    .cta--primary:hover { filter: brightness(0.96); }
    .cta--ghost:hover { border-color: var(--vermillion); }
  }
</style>
