---
// Homepage hero — name badge + eyebrow + H1 with highlighted keywords + Caveat subtitle + meta strip
---

<header class="hero">
  <div class="container">
    <h1 class="hero-h1">
      Is training <span class="hl hl--vermillion tilt-l">actually</span><br />
      the answer <span class="nobreak"><span class="hl hl--lime tilt-r">here</span>?</span>
    </h1>

    <p class="hero-sub">…or did everyone just panic and ask for slides?</p>

    <div class="hero-meta">
      <div class="meta-item">
        <strong>Based</strong>
        <span>Nashville, TN · Central Time</span>
      </div>
      <div class="meta-item">
        <strong>Focus</strong>
        <span>Learning · Performance · Tech</span>
      </div>
      <div class="meta-item">
        <strong>Email</strong>
        <a href="mailto:casey@caseyshiray.com">casey@caseyshiray.com</a>
      </div>
    </div>
  </div>

  <span class="hero-bloom hero-bloom--1" aria-hidden="true"></span>
  <span class="hero-bloom hero-bloom--2" aria-hidden="true"></span>
</header>

<style>
  .hero {
    position: relative;
    padding: 96px 0 80px;
    overflow: hidden;
  }
  .hero-h1 {
    font-size: clamp(56px, 9vw, 120px);
    line-height: 0.95;  /* minimum that clears the cap-height + descender + .hl top-padding stack;
                           anything tighter mathematically forces the highlight to overlap the line above */
    max-width: 1100px;
  }

  .hero-sub {
    margin-top: 28px;
    font-family: var(--font-hand);
    font-size: clamp(28px, 3.4vw, 42px);
    color: var(--tertiary-loud);  /* swaps plum→lavender on dark */
    line-height: 1.2;
  }

  .hero-meta {
    margin-top: 48px;
    display: flex;
    flex-wrap: wrap;
    gap: 32px;
  }
  .meta-item {
    font-family: var(--font-mono);
    font-size: 13px;
    color: var(--text-soft);
    line-height: 1.5;
  }
  .meta-item strong {
    display: block;
    font-size: 14px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--text);
    opacity: 0.75;
    font-weight: 600;
    margin-bottom: 4px;
  }
  .meta-item a { color: inherit; }
  .meta-item a:hover { color: var(--vermillion); }

  .hero-bloom {
    position: absolute;
    pointer-events: none;
    border-radius: 50%;
  }
  .hero-bloom--1 {
    top: -120px; right: -120px;
    width: 680px; height: 680px;
    background: radial-gradient(circle, rgba(255, 94, 58, 0.15) 0%, transparent 70%);
  }
  .hero-bloom--2 {
    bottom: -160px; left: 25%;
    width: 520px; height: 520px;
    background: radial-gradient(circle, rgba(255, 94, 58, 0.18) 0%, transparent 70%);
  }
  /* Dark-mode blooms use a small solid-color disc with a heavy Gaussian blur
     instead of a radial gradient. A gradient has a literal edge — alpha hits
     zero at the box boundary, and against a dark surface even alpha 0.005→0
     reads as a visible curve. Blur produces a Gaussian falloff that
     asymptotically approaches 0 — perceptually edgeless.

     Tune the look by editing the four vars below in one place; both blooms
     read from them. Only per-bloom positions are defined separately. */
  [data-theme="dark"] .hero-bloom {
    --bloom-rgb: 200, 180, 208;  /* lavender — low contrast against dark bg keeps edge soft */
    --bloom-alpha: 0.13;          /* peak source alpha; perceived brightness scales linearly */
    --bloom-size: 320px;          /* disc diameter before blur */
    --bloom-blur: 120px;          /* blur radius; bigger = softer falloff and wider visible glow */

    width: var(--bloom-size);
    height: var(--bloom-size);
    background: rgba(var(--bloom-rgb), var(--bloom-alpha));
    filter: blur(var(--bloom-blur));
  }
  [data-theme="dark"] .hero-bloom--1 {
    top: -80px;
    right: -80px;
  }
  [data-theme="dark"] .hero-bloom--2 {
    bottom: -100px;
    left: 22%;
  }
</style>
